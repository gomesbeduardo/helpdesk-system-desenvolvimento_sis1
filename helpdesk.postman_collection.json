{
  "info": {
    "name": "Help Desk API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:3001" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [{ "listen": "test", "script": { "exec": [
            "var res = pm.response.json();",
            "pm.collectionVariables.set('token', res.token);"
          ], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@helpdesk.com\",\n  \"password\": \"admin123\"\n}" },
            "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Cadastrar usuário",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Novo Usuário\",\n  \"email\": \"novo@email.com\",\n  \"password\": \"senha123\"\n}" },
            "url": { "raw": "{{base_url}}/users", "host": ["{{base_url}}"], "path": ["users"] }
          }
        },
        {
          "name": "Listar usuários (admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/users", "host": ["{{base_url}}"], "path": ["users"] }
          }
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "Listar categorias",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/categories", "host": ["{{base_url}}"], "path": ["categories"] }
          }
        },
        {
          "name": "Criar categoria (admin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Nova Categoria\",\n  \"description\": \"Descrição da categoria\"\n}" },
            "url": { "raw": "{{base_url}}/categories", "host": ["{{base_url}}"], "path": ["categories"] }
          }
        },
        {
          "name": "Atualizar categoria (admin)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Categoria Atualizada\",\n  \"description\": \"Nova descrição\"\n}" },
            "url": { "raw": "{{base_url}}/categories/:id", "host": ["{{base_url}}"], "path": ["categories", ":id"], "variable": [{ "key": "id", "value": "ID_DA_CATEGORIA" }] }
          }
        },
        {
          "name": "Excluir categoria (admin)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/categories/:id", "host": ["{{base_url}}"], "path": ["categories", ":id"], "variable": [{ "key": "id", "value": "ID_DA_CATEGORIA" }] }
          }
        }
      ]
    },
    {
      "name": "Tickets",
      "item": [
        {
          "name": "Listar chamados",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/tickets?status=open&page=1&limit=10",
              "host": ["{{base_url}}"],
              "path": ["tickets"],
              "query": [
                { "key": "status", "value": "open" },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Criar chamado",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"Problema no computador\",\n  \"description\": \"O computador não liga após atualização.\",\n  \"priority\": \"high\",\n  \"category_id\": \"ID_DA_CATEGORIA\"\n}" },
            "url": { "raw": "{{base_url}}/tickets", "host": ["{{base_url}}"], "path": ["tickets"] }
          }
        },
        {
          "name": "Buscar chamado por ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/tickets/:id", "host": ["{{base_url}}"], "path": ["tickets", ":id"], "variable": [{ "key": "id", "value": "ID_DO_CHAMADO" }] }
          }
        },
        {
          "name": "Alterar status (técnico/admin)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"in_progress\"\n}" },
            "url": { "raw": "{{base_url}}/tickets/:id/status", "host": ["{{base_url}}"], "path": ["tickets", ":id", "status"], "variable": [{ "key": "id", "value": "ID_DO_CHAMADO" }] }
          }
        },
        {
          "name": "Listar comentários",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/tickets/:id/comments", "host": ["{{base_url}}"], "path": ["tickets", ":id", "comments"], "variable": [{ "key": "id", "value": "ID_DO_CHAMADO" }] }
          }
        },
        {
          "name": "Adicionar comentário",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"message\": \"Estamos verificando o problema.\"\n}" },
            "url": { "raw": "{{base_url}}/tickets/:id/comments", "host": ["{{base_url}}"], "path": ["tickets", ":id", "comments"], "variable": [{ "key": "id", "value": "ID_DO_CHAMADO" }] }
          }
        },
        {
          "name": "Histórico de status",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/tickets/:id/history", "host": ["{{base_url}}"], "path": ["tickets", ":id", "history"], "variable": [{ "key": "id", "value": "ID_DO_CHAMADO" }] }
          }
        }
      ]
    }
  ]
}
